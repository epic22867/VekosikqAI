# Public ngrok URL pointing to your Ollama server (e.g. https://abcd-1-2-3-4.ngrok-free.app)
OLLAMA_BASE_URL=https://your-ngrok-url.ngrok-free.app

# Model names as pulled in Ollama
TEXT_MODEL=qwen3:8b
VISION_MODEL=qwen2.5vl:3b

# Tavily API key (https://tavily.com)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxx

# Railway sets PORT automatically, default for local dev
PORT=3000
